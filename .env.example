# Salesforce credentials — copy this to .env and fill in your values
# Never commit .env to git

SF_USERNAME=your.email@example.com
SF_PASSWORD=yourpassword
SF_SECURITY_TOKEN=yourSecurityToken
SF_DOMAIN=login
# SF_DOMAIN=test   ← use this if connecting to a sandbox

# Transport mode
# stdio = local (Claude Code)
# sse   = remote (Render / Claude Web)
TRANSPORT=stdio
